generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Stores customer profile and license details.
model Customer {
  customer_id Int     @id @default(autoincrement())
  first_name  String  @db.VarChar(50)
  last_name   String  @db.VarChar(50)
  street      String? @db.VarChar(100)
  city        String? @db.VarChar(50)
  state       String? @db.VarChar(50)
  zip         String? @db.VarChar(10)
  license_no  String  @unique @db.VarChar(20)

  phones   CustomerPhone[]
  bookings Booking[]
}

// Stores customer phone numbers (one customer can have multiple numbers).
model CustomerPhone {
  customer_id  Int
  phone_number String @db.VarChar(15)

  customer Customer @relation(fields: [customer_id], references: [customer_id])

  @@id([customer_id, phone_number])
  @@map("customer_phone")
}

// Stores rental vehicle inventory and pricing info.
model Vehicle {
  vehicle_id          Int                 @id @default(autoincrement())
  brand               String              @db.VarChar(50)
  fuel_type           FuelType?
  model               String              @db.VarChar(50)
  rental_rate         Decimal?            @db.Decimal(12, 2)
  availability_status AvailabilityStatus? @default(available)

  bookings Booking[]
}

// Stores booking transactions linking customers and vehicles.
model Booking {
  booking_id     Int            @id @default(autoincrement())
  customer_id    Int
  vehicle_id     Int
  booking_date   DateTime       @db.Date
  pickup_date    DateTime       @db.Date
  return_date    DateTime       @db.Date
  booking_status BookingStatus? @default(pending)
  total_amount   Decimal        @db.Decimal(10, 2)

  customer Customer @relation(fields: [customer_id], references: [customer_id])
  vehicle  Vehicle  @relation(fields: [vehicle_id], references: [vehicle_id])
  payment  Payment?

  @@index([customer_id])
  @@index([vehicle_id])
}

// Stores payment entries; mapped to legacy column name payment_id in DB.
model Payment {
  booking_id     Int            @id @map("payment_id")
  payment_date   DateTime       @db.Date
  payment_method String         @db.VarChar(50)
  payment_status PaymentStatus? @default(pending)

  booking Booking @relation(fields: [booking_id], references: [booking_id])

  @@map("payment")
}

// Allowed fuel categories for vehicles.
enum FuelType {
  petrol
  diesel
  electric
}

// Allowed availability values for vehicle status.
enum AvailabilityStatus {
  available
  booked
}

// Allowed lifecycle states for bookings.
enum BookingStatus {
  pending
  confirmed
  cancelled
}

// Allowed lifecycle states for payments.
enum PaymentStatus {
  pending
  in_progress
  done
}
